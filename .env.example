# =============================================================================
# YADEM AI Engine - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Application ---
APP_NAME=YADEM AI Credit Decisioning Engine
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# --- Database ---
DATABASE_URL=postgresql+asyncpg://yadem:yadem_pass@localhost:5432/yadem_db
DATABASE_SYNC_URL=postgresql://yadem:yadem_pass@localhost:5432/yadem_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=yadem-credit-scoring

# --- Model Config ---
MODEL_REGISTRY_PATH=./models
ENSEMBLE_WEIGHTS_LR=0.25
ENSEMBLE_WEIGHTS_RF=0.35
ENSEMBLE_WEIGHTS_XGB=0.40

# --- Risk Band Thresholds ---
RISK_BAND_A_MIN=800
RISK_BAND_B_MIN=650
RISK_BAND_C_MIN=500
RISK_BAND_D_MIN=300

# --- Security ---
AES_ENCRYPTION_KEY=your-32-byte-aes-key-here-change
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- External APIs (placeholders for future integration) ---
NIBSS_API_KEY=
NIBSS_API_URL=https://api.nibss-plc.com.ng
CRC_API_KEY=
CRC_API_URL=https://api.creditreferencenigeria.net
FIRST_CENTRAL_API_KEY=
XDS_API_KEY=
MONO_API_KEY=
MONO_API_URL=https://api.withmono.com
